generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @unique
  role           Role
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  profilePic     String
  facultyProfile FacultyProfile?
  notifications  Notification[]
  studentProfile StudentProfile?
  tickets        Ticket[]
}

model StudentProfile {
  id                  Int                  @id @default(autoincrement())
  userId              Int                  @unique
  rollNumber          String               @unique
  designation         String
  department          String
  appointmentRequests AppointmentRequest[]
  appointments        AppointmentUsers[]
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FacultyProfile {
  id                  Int                   @id @default(autoincrement())
  userId              Int                   @unique
  department          String
  designation         String
  appointmentRequests AppointmentRequest[]
  busyblocks          Busyblocks[]
  availabilities      FacultyAvailability[]
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppointmentRequest {
  id               Int                @id @default(autoincrement())
  studentId        Int
  facultyId        Int
  start            DateTime
  status           Status             @default(PENDING)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  note             String?
  purpose          String
  end              DateTime
  cancellationNote String?
  capacity         Int
  isGroup          Boolean            @default(false)
  recurrenceId     String?
  recurrenceRule   String?
  faculty          FacultyProfile     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  student          StudentProfile     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  students         AppointmentUsers[]
}

model AppointmentUsers {
  id            Int                @id @default(autoincrement())
  appointmentId Int
  userId        Int
  appointment   AppointmentRequest @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  student       StudentProfile     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, userId])
}

model FacultyAvailability {
  id        Int            @id @default(autoincrement())
  start     DateTime
  end       DateTime
  facultyId Int
  faculty   FacultyProfile @relation(fields: [facultyId], references: [id], onDelete: Cascade)
}

model Timetable {
  id          Int    @id @default(autoincrement())
  facultyName String
  day         String
  time        String
}

model Busyblocks {
  id        Int            @id @default(autoincrement())
  facultyId Int
  start     DateTime
  end       DateTime
  faculty   FacultyProfile @relation(fields: [facultyId], references: [id], onDelete: Cascade)
}

model Ticket {
  id           Int      @id @default(autoincrement())
  topic        String
  description  String?
  ticketStatus TSVAL    @default(OPEN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  link      String?
  user      User     @relation(fields: [userId], references: [id])
}

enum Status {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum Role {
  ADMIN
  FACULTY
  STUDENT
}

enum TSVAL {
  OPEN
  RESOLVED
}
